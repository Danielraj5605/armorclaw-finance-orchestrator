# ── Alpaca Paper Trading ─────────────────────────────────────────
# Get keys at: https://app.alpaca.markets/paper/dashboard
ALPACA_API_KEY=your_alpaca_paper_api_key
ALPACA_SECRET_KEY=your_alpaca_paper_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── LLM Configuration ────────────────────────────────────────────
# Default: Gemini 2.5 Flash (free tier, 1500 requests/day)
# Get key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key

# LLM provider override (gemini | openai | anthropic | ollama)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash-preview

# Optional: OpenAI fallback
# OPENAI_API_KEY=sk-...

# ── ArmorClaw / OpenClaw ─────────────────────────────────────────
# HMAC signing secret for delegation tokens (min 32 chars)
ARMORCLAW_SECRET_KEY=auratrade-demo-secret-key-change-in-prod!

# ArmorIQ API key — get at: https://platform.armoriq.ai
ARMORIQ_API_KEY=ak_live_your_armoriq_key_here

# OpenClaw mode:
#   demo  = simulated pipeline, no real daemon needed (default)
#   live  = connects to real OpenClaw daemon at OPENCLAW_WS
OPENCLAW_MODE=demo

# OpenClaw daemon WebSocket URL (only used when OPENCLAW_MODE=live)
OPENCLAW_WS=ws://127.0.0.1:18789

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./auratrade_audit.db

# ── FastAPI ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
INTENT_FILE_PATH=./intent.json
